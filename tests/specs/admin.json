[
  {
    "name": "/admin shows dashboard",
    "steps": [
      {
        "send": { "text": "/admin" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Admin Dashboard\n\nManage your studio:"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/admin then back to menu",
    "steps": [
      {
        "send": { "text": "/admin" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Admin Dashboard\n\nManage your studio:"
            }
          }
        ]
      },
      {
        "send": { "callback": "menu:main" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "👋 Welcome! Tap a button below to get started."
            }
          }
        ]
      }
    ]
  }
]
